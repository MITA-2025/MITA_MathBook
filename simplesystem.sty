% 结构 | Structure

\NewDocumentCommand \Structure {m +m} {

    \group_begin:

    \phantomsection
    \label{·\g_chaptername_tl·\g_subchaptername_tl|#1}

    \tl_set:Nn \l_content_tl {#2}
    \g_translate_format:N \l_content_tl

    \tl_set:Nn \parttitlename {?}
    \tl_set:Nn \chaptername {!}
    \tl_set:Nn \subchaptername {!}
    \tl_set:Nn \sectionname {!}
    \tl_set:Nn \blockname {#1}
    \tl_set_eq:NN \blockcontent \l_content_tl
    \tl_set:Nn \linktext {!}
    \tl_set:Nn \parameterA {!}
    \tl_set:Nn \parameterB {!}

    {\g_StructureName_format_tl}
    {\g_StructureContent_format_tl}

    \regex_match:nVTF { \c{Equation}\s*\{.*\}\s*\Z } \l_content_tl
    {\vspace{-20pt}} {\vspace{4pt}}

    \group_end:

}

