    \IfNoValueTF {#2} {
        \prop_gput:Nnn \g_blockname_prop {#1} {#1}
        \tl_set:Nn \l_tmpd_tl {#1}
    } {
        \prop_gput:Nnn \g_blockname_prop {#1} {#2}
        \tl_set:Nn \l_tmpd_tl {#2}
    }

    \phantomsection
    \label{·\g_chaptername_tl·\g_subchaptername_tl|#1}

    \tl_set:Nn \l_content_tl {#4}
    \g_translate_format:N \l_content_tl

    \tl_set:Nn \parttitlename {?}
    \tl_set_eq:NN \chaptername \g_chaptername_tl
    \tl_set_eq:NN \subchaptername \g_subchaptername_tl
    \tl_set_eq:NN \blockname \l_tmpd_tl
    \tl_set_eq:NN \blockcontent \l_content_tl
    \tl_set_eq:NN \parameterA \g_parameterA_tl
    \tl_set:Nn \parameterB {#3}

